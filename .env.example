SECRET_KEY=change-me
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/real_estate?charset=utf8mb4
TEST_DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/real_estate_test?charset=utf8mb4
CRAWL_MAX_WORKERS=4
CRAWL_REQUEST_TIMEOUT=15
CRAWL_INTERVAL_MIN=1.0
CRAWL_INTERVAL_MAX=3.0

# 可选：登录后从浏览器复制 Cookie。只用于正常登录态访问，不绕验证码。
LIANJIA_COOKIE=
ANJUKE_COOKIE=

# DeepSeek Agent。真实 Key 只放 .env，不要提交。
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=30

# APScheduler 后台调度。默认关闭，演示或部署时再开启。
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Shanghai
QUALITY_REPORT_JOB_ENABLED=true
QUALITY_REPORT_INTERVAL_HOURS=24
INCREMENTAL_CRAWL_JOB_ENABLED=false
INCREMENTAL_CRAWL_INTERVAL_HOURS=24
INCREMENTAL_CRAWL_SOURCE=fang
INCREMENTAL_CRAWL_DISTRICTS=两江新区
INCREMENTAL_CRAWL_MAX_PAGES=1
INCREMENTAL_CRAWL_MAX_WORKERS=3

# 可选：高德地图前端能力。真实 Key 请放入 .env.local 或 Frontend/.env.local，不要提交源码。
# 当前重庆区县统计地图使用本地 GeoJSON + /api/charts/district-map，不依赖高德 Key。
VITE_AMAP_WEB_KEY=
VITE_AMAP_SECURITY_CODE=
